# ==============================================================================
# INDUSTRIAL_NLP_TEMPLATE - Environment Configuration Template
# 
# Инструкция:
# 1. Скопируй этот файл: cp .env.example .env
# 2. Заполни пропущенные значения (особенно API ключи).
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Инфраструктура (Порты)
# Если 8000 или 6333 заняты, измени их здесь. Docker Compose подхватит новые.
# ------------------------------------------------------------------------------
API_PORT=8000
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
AIRFLOW_PORT=8080

# ------------------------------------------------------------------------------
# 2. Аутентификация и Доступ к моделям
# ------------------------------------------------------------------------------
# Токен HuggingFace (необходим для загрузки Gated моделей, например Llama-3 или Mistral)
HF_TOKEN=your_hf_token_here
KAGGLE_USERNAME=fdgdgfdg
KAGGLE_KEY=аывпыррапра
# Токен для Telegram бота (если планируешь запускать бота)
TG_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# ------------------------------------------------------------------------------
# 3. Эксперименты и трекинг (MLFlow / W&B)
# ------------------------------------------------------------------------------
# Если используешь MLFlow или Weights & Biases, пропиши ключи здесь
MLFLOW_TRACKING_URI=http://localhost:5000
WANDB_API_KEY=your_wandb_api_key_here

# ------------------------------------------------------------------------------
# 4. Настройки приложения
# ------------------------------------------------------------------------------
# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
PYTHONIOENCODING=utf-8
PYTHONUTF8=1

# Если нужно, чтобы API смотрело на конкретную базу Qdrant (по умолчанию http://qdrant:6333)
# QDRANT_URL=http://qdrant:6333