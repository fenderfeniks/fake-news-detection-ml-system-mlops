{
  "etl_config": {
    "schedule": "0 2 * * *",
    "pvc_name": "pvc-data",
    "mount_path": "/app/data",
    "resources": {
      "requests": {"cpu": "0.5", "memory": "1Gi"},
      "limits": {"cpu": "1", "memory": "2Gi"}
    },
    "default_args": {
      "owner": "ml_team",
      "retries": 2,
      "retry_delay_minutes": 3
    }
  },

  "analytics_config": {
    "schedule": "0 8 * * *",
    "db_secret_name": "analytics-db-secrets",
    "resources": {
      "requests": {"cpu": "0.5", "memory": "1Gi"},
      "limits": {"cpu": "1", "memory": "2Gi"}
    },
    "default_args": {
      "owner": "ml_team",
      "retries": 3,
      "retry_delay_minutes": 5
    }
  },

  "evaluation_config": {
    "schedule": "@weekly",
    "drift_threshold": 0.9,
    "pvc_name": "pvc-models",
    "mount_path": "/app/models",
    "resources": {
      "requests": {"cpu": "0.5", "memory": "1Gi"},
      "limits": {"cpu": "1", "memory": "2Gi"}
    },
    "default_args": {
      "owner": "ml_team",
      "retries": 1,
      "retry_delay_minutes": 5
    }
  },

  "maintenance_config": {
    "schedule": "0 3 * * 0",
    "retention_days": 30,
    "mlruns_pvc_name": "logs-pvc",
    "mlruns_mount_path": "/app/logs",
    "resources": {
      "requests": {"cpu": "0.5", "memory": "1Gi"},
      "limits": {"cpu": "1", "memory": "2Gi"}
    },
    "default_args": {
      "owner": "ml_team",
      "retries": 1,
      "retry_delay_minutes": 5
    }
  },

  "training_config": {
    "schedule": "@weekly",
    "pvc_name": "pvc-models",
    "mount_path": "/app/models",
    "resources": {
      "requests": {"cpu": "0.5", "memory": "1Gi"},
      "limits": {"cpu": "1", "memory": "2Gi"}
    },
    "default_args": {
      "owner": "ml_team",
      "retries": 1,
      "retry_delay_minutes": 5
    }
  }
}